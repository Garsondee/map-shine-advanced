{
  "id": "map-shine-advanced",
  "title": "Map Shine Advanced",
  "description": "This Foundry VTT module is designed to bring the capabilities of three.js into Foundry VTT with a focus on producing 2.5 battlemaps with BPR shading, particles and advanced rendering options.",
  "version": "0.3.0.6",
  "library": "false",
  "manifestPlusVersion": "1.2.0",
  "compatibility": {
    "minimum": "14",
    "verified": "14",
    "maximum": "14"
  },
  "authors": [
    {
      "name": "Ingram Blakelock",
      "url": "https://github.com/Garsondee/map-shine-advanced",
      "discord": "garsondee"
    }
  ],
  "relationships": {
    "systems": [],
    "requires": [],
    "recommends": [
      {
        "id": "dice-so-nice",
        "type": "module",
        "reason": "Map Shine Advanced composites Dice So Nice's roll canvas inside its Three.js post-processing pipeline (bloom, color grade, lens). Toggle in Graphics Settings.",
        "compatibility": {
          "verified": "6.0.0"
        }
      },
      {
        "id": "sequencer",
        "type": "module",
        "reason": "Map Shine Advanced mirrors Sequencer effects (including JB2A) into its Three.js scene so they receive in-scene lighting and post-FX. Toggle in Graphics Settings.",
        "compatibility": {
          "verified": "4.0.1"
        }
      }
    ]
  },
  "esmodules": [
    "scripts/vendor/tweakpane-loader.js",
    "scripts/module.js"
  ],
  "scripts": [
    "scripts/lib/lib.js"
  ],
  "styles": [
    "styles/module.css"
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "languages/en.json"
    }
  ],
  "url": "https://github.com/Garsondee/map-shine-advanced",
  "manifest": "https://github.com/Garsondee/map-shine-advanced/releases/latest/download/module.json",
  "download": "https://github.com/Garsondee/map-shine-advanced/releases/latest/download/module.zip",
  "license": "LICENSE",
  "readme": "README.md",
  "media": [
